params {
    input_dir = null
    outdir = null
    genome = null
    bowtie2_index = null
    chrom_sizes = null
    blacklist = null
    annotation_gtf = null
    tss_bed = null
    association_csv = null

    adapter_fwd = 'CTGTCTCTTATACACATCT'
    adapter_rev = 'CTGTCTCTTATACACATCT'
    min_read_length = 20
    cutadapt_extra = ''

    paired_pattern = ''
    threads = 8
    align_cpus = 8
    bowtie2_options = '--very-sensitive --dovetail --no-mixed --no-discordant'
    mapq = 10
    mito_chroms = 'chrM,MT,M,MtDNA,chrMT'

    dedup_mode = 'picard'
    umi_enabled = false
    umi_tools_options = '--paired'

    normalize_using = 'CPM'
    effective_genome_size = null
    bigwig_bin_size = 10
    bamcoverage_extra = ''
    make_bedgraph = true

    macs3_qvalue = 0.01
    macs3_broad_cutoff = 0.1
    macs3_genome_size = 'auto'
    macs3_extra = ''
    allow_control_free_peak_calling = false
    call_control_peaks = false
    allow_extra_association_rows = false

    promoter_upstream = 2000
    promoter_downstream = 500
    downstream_window = 3000
    tss_window = 3000
    tss_center_window = 100
    peak_center_window = 3000

    container = null
    singularity_cache = "${projectDir}/.singularity"
}

process {
    shell = ['/bin/bash', '-euo', 'pipefail']
    cpus = { params.threads as int }
    memory = '8 GB'
    time = '8h'
    errorStrategy = { task.exitStatus in [130,137,140,143] ? 'retry' : 'terminate' }
    maxRetries = 1
    publishDir = [
        path: { "${params.outdir}" },
        mode: 'copy',
        overwrite: true,
        saveAs: { filename -> filename }
    ]

    withLabel: small {
        cpus = 1
        memory = '4 GB'
        time = '2h'
    }
    withLabel: medium {
        cpus = { Math.max(2, Math.min(params.threads as int, 8)) }
        memory = '16 GB'
        time = '12h'
    }
    withLabel: large {
        cpus = { Math.max(4, params.align_cpus as int) }
        memory = '32 GB'
        time = '48h'
    }
}

timeline {
    enabled = true
    file = "${params.outdir ?: 'results'}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file = "${params.outdir ?: 'results'}/pipeline_info/execution_report.html"
}
trace {
    enabled = true
    file = "${params.outdir ?: 'results'}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    file = "${params.outdir ?: 'results'}/pipeline_info/pipeline_dag.html"
}

manifest {
    name = 'cutntag-pe-nextflow'
    description = 'Production-oriented paired-end CUT&Tag DSL2 pipeline'
    version = '0.1.0'
    nextflowVersion = '>=24.10.0'
}
